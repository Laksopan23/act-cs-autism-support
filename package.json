{
  "name": "autismcare-integrated-platform",
  "version": "1.0.0",
  "description": "AutismCare clinical support platform",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install --prefix backend && cd ai-service && .\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt",
    "seed": "npm run seed --prefix backend",
    "start": "START_ALL.bat",
    "start:frontend": "npm start --prefix frontend",
    "start:backend": "npm run dev --prefix backend",
    "start:ai": "cd ai-service && .\\.venv\\Scripts\\python.exe -m uvicorn main:app --port 8000"
  },
  "keywords": [
    "autism",
    "therapy",
    "ai",
    "react",
    "express",
    "fastapi"
  ],
  "author": "Antigravity AI",
  "license": "ISC"
}
